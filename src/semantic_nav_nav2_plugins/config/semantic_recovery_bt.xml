<!--
  BT-LR M5: OperatorPrompt + nested Switch3 for operator-action directives.

  outer Switch3 cases: retry_target, wait_then_replan, give_up.
  outer Switch3 default: inner Switch3 for operator actions
    (open_door_then_replan, clear_object_then_replan).
  OperatorPrompt blocks on /operator_decision up to response_timeout_ms.
  Returns SUCCESS on operator ack, FAILURE on rejection/timeout.
-->
<root main_tree_to_execute="SemanticNavigateWithRecovery">

  <BehaviorTree ID="SemanticNavigateWithRecovery">

    <RecoveryNode number_of_retries="3" name="SemanticRecovery">

      <!-- ===== Primary child: validate, plan, check corridor, follow ===== -->
      <PipelineSequence name="NavigateWithValidation">

        <ValidateSemantic
            service_name="/validate_pose_goal"
            server_timeout="10000"
            goal_pose="{goal}"
            validation_reason="{validation_reason}"/>

        <ComputePathToPose
            goal="{goal}"
            path="{path}"
            planner_id="GridBased"/>

        <PathClearCondition
            path="{path}"
            lookahead_m="1.5"
            lethal_threshold="90"
            debounce_ticks="2"
            sample_radius_m="0.05"
            plan_topic="/plan"
            local_costmap_topic="/local_costmap/costmap"
            blockage_centroid="{blockage_centroid}"
            blockage_extent_m="{blockage_extent_m}"/>

        <FollowPath
            path="{path}"
            controller_id="FollowPath"/>

      </PipelineSequence>

      <!-- ===== Recovery child: context → escalate → directive branch ===== -->
      <Sequence name="SemanticRecoveryBranch">

        <QuerySemanticContext
            blockage_centroid="{blockage_centroid}"
            blockage_extent_m="{blockage_extent_m}"
            radius_m="4.0"
            service_ready_timeout_ms="2000"
            response_timeout_ms="30000"
            refresh_service="/refresh_local_objects"
            match_service="/match_responsible_object"
            responsible_object_key="{responsible_object_key}"
            responsible_object_tag="{responsible_object_tag}"
            responsible_object_state="{responsible_object_state}"
            responsible_safety_class="{responsible_safety_class}"
            responsible_openable="{responsible_openable}"
            responsible_clearable="{responsible_clearable}"
            local_db_version="{local_db_version}"
            local_db_source="{local_db_source}"/>

        <EscalateToLLMRecovery
            service_name="/request_recovery"
            server_timeout="300000"
            failure_stage="execution"
            nav2_message="path blocked or navigation aborted"
            original_object_tag="{original_object_tag}"
            original_intent_hint="{original_intent_hint}"
            current_target_object_key="{current_target_object_key}"
            responsible_object_key="{responsible_object_key}"
            responsible_object_tag="{responsible_object_tag}"
            responsible_object_state="{responsible_object_state}"
            responsible_safety_class="{responsible_safety_class}"
            responsible_openable="{responsible_openable}"
            responsible_clearable="{responsible_clearable}"
            blockage_centroid="{blockage_centroid}"
            blockage_extent_m="{blockage_extent_m}"
            local_db_version="{local_db_version}"
            local_db_source="{local_db_source}"
            directive_action="{directive_action}"
            directive_target_pose="{directive_target_pose}"
            directive_target_object_key="{directive_target_object_key}"
            directive_target_object_tag="{directive_target_object_tag}"
            directive_target_intent_hint="{directive_target_intent_hint}"
            directive_wait_seconds="{directive_wait_seconds}"
            directive_emit_signal_during_wait="{directive_emit_signal_during_wait}"
            directive_signal_attempts="{directive_signal_attempts}"
            directive_operator_message="{directive_operator_message}"
            directive_rationale="{directive_rationale}"
            directive_confidence_percent="{directive_confidence_percent}"
            directive_escalate_to_operator="{directive_escalate_to_operator}"
            recovery_event_id="{recovery_event_id}"/>

        <Switch3
            variable="{directive_action}"
            case_1="retry_target"
            case_2="wait_then_replan"
            case_3="give_up">

          <!-- retry_target: goal is already updated by EscalateToLLMRecovery -->
          <Sequence name="RetryTargetBranch">
            <ClearEntireCostmap
                name="ClearGlobalRetry"
                service_name="global_costmap/clear_entirely_global_costmap"/>
            <ClearEntireCostmap
                name="ClearLocalRetry"
                service_name="local_costmap/clear_entirely_local_costmap"/>
          </Sequence>

          <!-- wait_then_replan: M4 signal-wait-recheck or passive-wait -->
          <Fallback name="WaitThenReplanBranch">

            <!-- Branch A: signal-wait-recheck for animate obstacles.
                Gate EmitObstacleSignal returns FAILURE when emit_enabled=false
                so this Sequence fails and Fallback tries Branch B. -->
            <Sequence name="SignalWaitRecheck">
              <!-- Gate: emit_enabled controls entry; publish_signal="false" avoids
                  a redundant first-cycle signal before the retry loop begins. -->
              <EmitObstacleSignal
                  emit_enabled="{directive_emit_signal_during_wait}"
                  publish_signal="false"
                  signal_class="{responsible_safety_class}"
                  signal_topic="/robot_obstacle_signal"/>

              <RetryUntilSuccessful num_attempts="{directive_signal_attempts}">
                <Sequence name="SignalCycle">
                  <!-- Per-attempt publisher: emits once on each signal-wait-recheck cycle. -->
                  <EmitObstacleSignal
                      emit_enabled="true"
                      publish_signal="true"
                      signal_class="{responsible_safety_class}"
                      signal_topic="/robot_obstacle_signal"/>

                  <Wait wait_duration="2"/>

                  <PathClearCondition
                      path="{path}"
                      lookahead_m="1.5"
                      lethal_threshold="90"
                      debounce_ticks="1"
                      sample_radius_m="0.05"
                      plan_topic="/plan"
                      local_costmap_topic="/local_costmap/costmap"
                      blockage_centroid="{blockage_centroid}"
                      blockage_extent_m="{blockage_extent_m}"/>

                </Sequence>
              </RetryUntilSuccessful>

              <ClearEntireCostmap
                  name="ClearLocalSignal"
                  service_name="local_costmap/clear_entirely_local_costmap"/>

            </Sequence>

            <!-- Branch B: passive wait for non-animate obstacles or after
                signal retries are exhausted. -->
            <Sequence name="PassiveWait">

              <Wait wait_duration="{directive_wait_seconds}"/>

              <ClearEntireCostmap
                  name="ClearGlobalPassive"
                  service_name="global_costmap/clear_entirely_global_costmap"/>

              <ClearEntireCostmap
                  name="ClearLocalPassive"
                  service_name="local_costmap/clear_entirely_local_costmap"/>

            </Sequence>

          </Fallback>

          <!-- give_up: visible terminal failure branch -->
          <ForceFailure name="GiveUpTerminal">
            <AlwaysSuccess/>
          </ForceFailure>

          <!-- default: inner Switch3 for operator-action directives -->
          <Switch3 name="OperatorDirectiveSwitch"
                   variable="{directive_action}"
                   case_1="open_door_then_replan"
                   case_2="clear_object_then_replan"
                   case_3="__unused_operator_case__">

            <!-- open_door_then_replan: wait for operator to open door, then replan -->
            <Sequence name="OpenDoorThenReplanBranch">
              <OperatorPrompt
                  service_name="/operator_decision"
                  prompt_text="{directive_operator_message}"
                  responsible_object_key="{responsible_object_key}"
                  failure_stage="execution"
                  directive_action="{directive_action}"
                  recovery_event_id="{recovery_event_id}"
                  service_ready_timeout_ms="2000"
                  response_timeout_ms="120000"/>
              <ClearEntireCostmap
                  name="ClearGlobalOpenDoor"
                  service_name="global_costmap/clear_entirely_global_costmap"/>
              <ClearEntireCostmap
                  name="ClearLocalOpenDoor"
                  service_name="local_costmap/clear_entirely_local_costmap"/>
            </Sequence>

            <!-- clear_object_then_replan: wait for operator to remove obstacle, then replan -->
            <Sequence name="ClearObjectThenReplanBranch">
              <OperatorPrompt
                  service_name="/operator_decision"
                  prompt_text="{directive_operator_message}"
                  responsible_object_key="{responsible_object_key}"
                  failure_stage="execution"
                  directive_action="{directive_action}"
                  recovery_event_id="{recovery_event_id}"
                  service_ready_timeout_ms="2000"
                  response_timeout_ms="120000"/>
              <ClearEntireCostmap
                  name="ClearGlobalClearObject"
                  service_name="global_costmap/clear_entirely_global_costmap"/>
              <ClearEntireCostmap
                  name="ClearLocalClearObject"
                  service_name="local_costmap/clear_entirely_local_costmap"/>
            </Sequence>

            <!-- placeholder for case_3 — never reached in M5 -->
            <ForceFailure name="UnusedOperatorCase">
              <AlwaysSuccess/>
            </ForceFailure>

            <!-- default: truly unexpected directive string -->
            <ForceFailure name="UnexpectedDirective">
              <AlwaysSuccess/>
            </ForceFailure>

          </Switch3>

        </Switch3>

      </Sequence>

    </RecoveryNode>

  </BehaviorTree>

</root>