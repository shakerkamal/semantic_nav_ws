root ::= "{" ws action-pair "," ws tag-pair "," ws hint-pair "," ws conf-pair ws "}"
action-pair ::= "\"action\"" ws ":" ws action-value
tag-pair ::= "\"object_tag\"" ws ":" ws string
hint-pair ::= "\"intent_hint\"" ws ":" ws string
conf-pair ::= "\"confidence\"" ws ":" ws integer
action-value ::= "\"navigate\"" | "\"clarify\"" | "\"reject\""
string ::= "\"" char* "\""
char ::= [a-zA-Z0-9 ,._-]
integer ::= "0" | [1-9] [0-9]*
ws ::= ([ \t\n])*
