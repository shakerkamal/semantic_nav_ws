string query          # object key (e.g. "chair:2") or NL-resolved tag/key
string nl_command     # original NL text; empty for direct object commands
string intent_hint    # short semantic hint from LLM parse; empty for direct commands
---
bool success
string outcome        # REACHED | RESOLUTION_FAILED | NEEDS_OPERATOR | EXECUTION_FAILED | BUSY | INVALID
string failure_reason
