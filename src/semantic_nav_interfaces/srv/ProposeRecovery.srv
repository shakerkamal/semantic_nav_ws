bool success
string action
string target
string[] waypoints
string rationale
uint8 confidence_percent
string raw_output
string message

# --- BT-LLM response additions ---
string responsible_object_key
string operator_message
uint8 wait_seconds

# --- Object-centric retry_target fields (OC-M8) ---
string target_object_tag
